PORT=5001
# Optional: shown on GET /api/health for deploy/version dashboards
# APP_VERSION=1.0.0

MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/mockinterview
JWT_SECRET=replace_with_a_long_random_string

# Auth session cookie (httpOnly). In production, deploy behind HTTPS and keep SESSION_COOKIE_SECURE=true.
# AUTH_COOKIE_NAME=token
# SESSION_COOKIE_SECURE=true
# AUTH_TOKEN_IN_BODY=true

GEMINI_API_KEY=
# Optional override (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# Comma-separated origins for browser CORS (production + local)
FRONTEND_ORIGINS=http://localhost:3000

# Optional: tune rate limits (defaults are safe for dev)
# AUTH_RATE_LIMIT_MAX=40
# API_RATE_LIMIT_MAX=500
# CREATE_INTERVIEW_RATE_LIMIT_MAX=30

# Security hardening toggles
# NODE_ENV=production
