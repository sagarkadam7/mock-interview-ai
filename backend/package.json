{
  "name": "mock-interview-backend",
  "version": "1.0.0",
  "description": "AI Mock Interview Platform - Backend",
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node ./node_modules/jest/bin/jest.js",
    "test:watch": "node ./node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node ./node_modules/jest/bin/jest.js --coverage --coveragePathIgnorePatterns=/node_modules/",
    "format": "prettier --write \"**/*.{js,json,md}\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.24.1",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.2.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "jest": "^30.1.3",
    "nodemon": "^3.1.0",
    "prettier": "^3.8.3",
    "supertest": "^7.1.1"
  }
}
